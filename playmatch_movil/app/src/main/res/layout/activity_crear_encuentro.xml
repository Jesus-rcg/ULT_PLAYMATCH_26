<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2F4F7">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Toolbar -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical"
                android:background="#FFFFFF">

            <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="#16a34a"/>

            <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Crear Encuentro"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:gravity="center"/>

            <View
                    android:layout_width="40dp"
                    android:layout_height="40dp"/>

        </LinearLayout>

        <!-- Card formulario -->
        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                <!-- Torneo -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Torneo"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <Spinner
                        android:id="@+id/spinnerTorneo"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="16dp"/>

                <!-- Equipo Local -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Equipo Local"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <Spinner
                        android:id="@+id/spinnerEquipoLocal"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="16dp"/>

                <!-- Equipo Visitante -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Equipo Visitante"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <Spinner
                        android:id="@+id/spinnerEquipoVisitante"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="16dp"/>

                <!-- Jornada -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Jornada"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <EditText
                        android:id="@+id/etJornada"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Ej: 1"
                        android:padding="14dp"
                        android:background="@drawable/input_background"
                        android:inputType="number"
                        android:layout_marginBottom="16dp"/>

                <!-- Lugar -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lugar"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <EditText
                        android:id="@+id/etLugar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Ej: Estadio Central"
                        android:padding="14dp"
                        android:background="@drawable/input_background"
                        android:inputType="textCapWords"
                        android:layout_marginBottom="16dp"/>

                <!-- Fecha -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha (YYYY-MM-DD)"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <EditText
                        android:id="@+id/etFecha"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Ej: 2026-06-18"
                        android:padding="14dp"
                        android:background="@drawable/input_background"
                        android:inputType="date"
                        android:layout_marginBottom="16dp"/>

                <!-- Hora -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hora (HH:MM:SS)"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <EditText
                        android:id="@+id/etHora"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="Ej: 18:00:00"
                        android:padding="14dp"
                        android:background="@drawable/input_background"
                        android:inputType="time"
                        android:layout_marginBottom="16dp"/>

                <!-- Estado -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp"/>

                <Spinner
                        android:id="@+id/spinnerEstado"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/input_background"
                        android:layout_marginBottom="24dp"/>

                <!-- Botón guardar -->
                <Button
                        android:id="@+id/btnGuardar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="GUARDAR ENCUENTRO"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#16a34a"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>