<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0fff4">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <!-- Botón volver -->
        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#14532d"
                android:layout_marginBottom="8dp"/>

        <!-- Título -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ PLAYMATCH"
                android:textColor="#16a34a"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear Equipo"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="26sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ingresa los datos del nuevo equipo"
                android:textColor="#4ade80"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#bbf7d0"
                android:layout_marginBottom="20dp"/>

        <!-- Nombre del equipo -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del equipo"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etNombreEquipo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: Real Madrid"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp"/>

        <!-- Escudo -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Escudo (URL de la imagen)"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etEscudo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: https://miescudo.com/imagen.png"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="textUri"
                android:layout_marginBottom="24dp"/>

        <!-- Botón guardar -->
        <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GUARDAR EQUIPO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#16a34a"/>

    </LinearLayout>
</ScrollView>