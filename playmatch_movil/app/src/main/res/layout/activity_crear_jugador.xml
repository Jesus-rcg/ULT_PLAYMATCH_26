<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F5F5F5"
            android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

            <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Volver" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volver a Jugadores"
                    android:textColor="#534AB7"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp" />
        </LinearLayout>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crear Jugador"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="20dp"/>

        <!-- ID EQUIPO -->

        <Spinner
                android:id="@+id/spEquipos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>

        <!-- NOMBRE -->

        <EditText
                android:id="@+id/txtNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Nombre"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_marginBottom="12dp"/>

        <!-- APELLIDO -->

        <EditText
                android:id="@+id/txtApellido"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Apellido"
                android:inputType="textPersonName"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_marginBottom="12dp"/>

        <!-- DOCUMENTO -->

        <EditText
                android:id="@+id/txtDocumento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Documento"
                android:inputType="number"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_marginBottom="12dp"/>

        <!-- NUMERO CAMISETA -->

        <EditText
                android:id="@+id/txtNumeroCamiseta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Número camiseta"
                android:inputType="number"
                android:padding="12dp"
                android:background="@android:drawable/edit_text"
                android:layout_marginBottom="12dp"/>

        <!-- ESTADO -->

        <Spinner
                android:id="@+id/spEstadosJugador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"/>

        <!-- BOTON -->

        <Button
                android:id="@+id/btnGuardarJugador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Guardar Jugador"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#534AB7"
                android:padding="14dp"/>

    </LinearLayout>

</ScrollView>