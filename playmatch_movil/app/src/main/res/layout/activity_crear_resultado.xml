<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:fillViewport="true">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="40dp">

        <!-- Volver -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

            <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Volver"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volver a Resultados"
                    android:textColor="#534AB7"
                    android:textSize="13sp"
                    android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- Badge -->
        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="10dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="12dp">

            <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    app:srcCompat="@mipmap/guardar"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Guardar"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#3C3489"/>
        </LinearLayout>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nuevo resultado"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="4dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Completa todos los campos"
                android:textSize="13sp"
                android:textColor="#888780"
                android:layout_marginBottom="20dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encuentro"
                android:textSize="11sp"
                android:textColor="#888780"
                android:layout_marginBottom="4dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginBottom="12dp">

            <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    android:layout_marginEnd="8dp" />

            <Spinner
                    android:id="@+id/spEncuentro"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@null" />

        </LinearLayout>

        <!-- Goles Local -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goles Local"
                android:textSize="11sp"
                android:textColor="#888780"
                android:layout_marginBottom="4dp"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginBottom="12dp">

            <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_marginEnd="8dp"/>

            <EditText
                    android:id="@+id/etGolesLocal"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="0"
                    android:inputType="number"
                    android:background="@null"/>
        </LinearLayout>

        <!-- Goles Visitante -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goles Visitante"
                android:textSize="11sp"
                android:textColor="#888780"
                android:layout_marginBottom="4dp"/>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:layout_marginBottom="20dp">

            <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_marginEnd="8dp"/>

            <EditText
                    android:id="@+id/etGolesVisitante"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="0"
                    android:inputType="number"
                    android:background="@null"/>
        </LinearLayout>

        <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Guardar resultado"
                android:textColor="#EEEDFE"
                android:textStyle="bold"
                android:backgroundTint="#534AB7"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="El id_resultado se genera automáticamente"
                android:textSize="11sp"
                android:textColor="#BDBCB8"
                android:gravity="center"
                android:layout_marginTop="10dp"/>

    </LinearLayout>

</ScrollView>