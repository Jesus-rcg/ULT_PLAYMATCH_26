<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0fff4">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <!-- Botón volver -->
        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#14532d"
                android:layout_marginBottom="8dp"/>

        <!-- Título -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ PLAYMATCH"
                android:textColor="#16a34a"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Registrar Resultado"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="26sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#bbf7d0"
                android:layout_marginBottom="20dp"/>

        <!-- Spinner Encuentro -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Encuentro"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <Spinner
                android:id="@+id/spinnerEncuentro"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="16dp"/>

        <!-- Goles Local -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goles Local"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etGolesLocal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 2"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="number"
                android:layout_marginBottom="16dp"/>

        <!-- Goles Visitante -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Goles Visitante"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etGolesVisitante"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 1"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="number"
                android:layout_marginBottom="24dp"/>

        <!-- Botón guardar -->
        <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="GUARDAR RESULTADO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#16a34a"/>
        <!-- Spinner Torneo -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Torneo"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <Spinner
                android:id="@+id/spinnerTorneo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>