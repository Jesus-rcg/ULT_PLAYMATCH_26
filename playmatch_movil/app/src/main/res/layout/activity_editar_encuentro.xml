<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0fff4">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <!-- Botón volver -->
        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#14532d"
                android:layout_marginBottom="8dp"/>

        <!-- Título -->
        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ PLAYMATCH"
                android:textColor="#16a34a"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Editar Encuentro"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="26sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#bbf7d0"
                android:layout_marginBottom="20dp"/>

        <!-- Jornada -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jornada"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etJornadaEditar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 1"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="number"
                android:layout_marginBottom="16dp"/>

        <!-- Lugar -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lugar"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etLugarEditar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: Estadio Central"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp"/>

        <!-- Fecha -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha (YYYY-MM-DD)"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etFechaEditar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 2026-06-18"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="date"
                android:layout_marginBottom="16dp"/>

        <!-- Hora -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hora (HH:MM:SS)"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etHoraEditar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: 18:00:00"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="time"
                android:layout_marginBottom="16dp"/>

        <!-- Estado -->
        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Estado"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <Spinner
                android:id="@+id/spinnerEstadoEditar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="24dp"/>

        <!-- Botón actualizar -->
        <Button
                android:id="@+id/btnActualizar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ACTUALIZAR ENCUENTRO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#16a34a"/>

    </LinearLayout>
</ScrollView>