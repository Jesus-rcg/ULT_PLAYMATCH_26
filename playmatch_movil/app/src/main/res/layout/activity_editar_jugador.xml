<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#1A1A2E">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="40dp">

        <!-- BOTON VOLVER -->

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

            <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Volver"/>

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Volver"
                    android:textColor="#ffff"
                    android:textSize="14sp"/>
        </LinearLayout>

        <!-- TITULO -->

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Jugador"
                android:textStyle="bold"
                android:textSize="28sp"
                android:textColor="#FFFF"
                android:layout_marginBottom="20dp"/>

        <!-- CARD -->

        <androidx.cardview.widget.CardView
                android:id="@+id/cardJugador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                <!-- ID USUARIO -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID usuario"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <EditText
                        android:id="@+id/etIdUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="ID Usuario"
                        android:enabled="false"
                        android:layout_marginBottom="15dp"/>
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre Usuario"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <EditText
                        android:id="@+id/etNombre_usuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nombre Usuario"
                        android:inputType="text"
                        android:layout_marginBottom="15dp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apellido Usuario"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <EditText
                        android:id="@+id/etApellido_usuario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Apellido Usuario"
                        android:inputType="text"
                        android:layout_marginBottom="15dp"/>



                <!-- NUMERO CAMISETA -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Numero camiseta"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <EditText
                        android:id="@+id/etNumero"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Número Camiseta"
                        android:maxLength="3"
                        android:inputType="number"
                        android:layout_marginBottom="15dp"/>

                <!-- POSICION -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Posicion"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <Spinner
                        android:id="@+id/spPosicion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="25dp"/>



                <!-- ACTIVO -->
                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estado"
                        android:textStyle="bold"
                        android:layout_marginBottom="5dp"/>
                <Spinner
                        android:id="@+id/spActivo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="25dp"/>

                <!-- BOTON GUARDAR -->

                <Button
                        android:id="@+id/btnActualizar"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Guardar Cambios"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:backgroundTint="#2563EB"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>