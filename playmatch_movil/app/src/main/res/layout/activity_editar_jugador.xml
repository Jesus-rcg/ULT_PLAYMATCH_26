<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F3F4F6">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

        <!-- TITULO -->

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Editar Jugador"
                android:textStyle="bold"
                android:textSize="28sp"
                android:textColor="#111827"
                android:layout_marginBottom="20dp"/>

        <!-- BUSCADOR -->

        <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="18dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="20dp">

        </androidx.cardview.widget.CardView>

        <!-- CARD INFO JUGADOR -->

        <androidx.cardview.widget.CardView
                android:id="@+id/cardJugador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                <!-- NOMBRE -->

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="15dp">

                    <EditText
                            android:id="@+id/etNombre"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Nombre"
                            android:enabled="false"/>

                    <ImageButton
                            android:id="@+id/btnEditarNombre"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:backgroundTint="#2563EB"
                            android:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- APELLIDO -->

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="15dp">

                    <EditText
                            android:id="@+id/etApellido"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Apellido"
                            android:enabled="false"/>

                    <ImageButton
                            android:id="@+id/btnEditarApellido"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:backgroundTint="#2563EB"
                            android:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- DOCUMENTO -->

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="15dp">

                    <EditText
                            android:id="@+id/etDocumento"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Documento"
                            android:enabled="false"/>

                    <ImageButton
                            android:id="@+id/btnEditarDocumento"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:backgroundTint="#2563EB"
                            android:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- NUMERO CAMISETA -->

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="15dp">

                    <EditText
                            android:id="@+id/etNumero"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Número camiseta"
                            android:enabled="false"/>

                    <ImageButton
                            android:id="@+id/btnEditarNumero"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:backgroundTint="#2563EB"
                            android:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- ESTADO -->

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="25dp">

                    <EditText
                            android:id="@+id/etEstado"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Estado"
                            android:enabled="false"/>

                    <ImageButton
                            android:id="@+id/btnEditarEstado"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:src="@android:drawable/ic_menu_edit"
                            android:backgroundTint="#2563EB"
                            android:tint="#FFFFFF"/>
                </LinearLayout>

                <!-- BOTON -->

                <Button
                        android:id="@+id/btnActualizar"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Guardar Cambios"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:backgroundTint="#2563EB"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>