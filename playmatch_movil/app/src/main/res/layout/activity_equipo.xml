<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0fff4">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#14532d"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ PLAYMATCH"
                android:textColor="#16a34a"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Crear nuevo equipo"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="26sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Completa los datos del equipo"
                android:textColor="#4ade80"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#bbf7d0"
                android:layout_marginBottom="20dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Torneo"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <Spinner
                android:id="@+id/spinnerTorneo"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/spinner_background"
                android:padding="12dp"
                android:layout_marginBottom="14dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del equipo"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etNombre"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: Real Madrid"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="textCapWords"
                android:layout_marginBottom="14dp"/>

        <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entrenador"
                android:textColor="#15803d"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

        <EditText
                android:id="@+id/etEntrenador"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Ej: Carlo Ancelotti"
                android:padding="14dp"
                android:background="@drawable/input_background"
                android:inputType="textCapWords"
                android:layout_marginBottom="24dp"/>

        <Button
                android:id="@+id/btnGuardar"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="CREAR NUEVO EQUIPO"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#16a34a"
                android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>