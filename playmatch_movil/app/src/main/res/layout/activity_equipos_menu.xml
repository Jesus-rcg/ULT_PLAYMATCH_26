<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F2F4F7">

    <!-- Toolbar -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">

        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#16a34a"/>

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Equipos"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"/>

        <View
                android:layout_width="40dp"
                android:layout_height="40dp"/>

    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Qué quieres hacer?"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingVertical="12dp"/>

    <!-- Opciones -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <!-- Crear -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                <Button
                        android:id="@+id/btnCrear"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Crear Equipo"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#16a34a"/>

            </androidx.cardview.widget.CardView>

            <!-- Ver todos -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                <Button
                        android:id="@+id/btnVerTodos"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Ver Todos"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#2563EB"/>

            </androidx.cardview.widget.CardView>

            <!-- Editar -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                <Button
                        android:id="@+id/btnEditar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Editar Equipo"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#D97706"/>

            </androidx.cardview.widget.CardView>

            <!-- Eliminar -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                <Button
                        android:id="@+id/btnEliminar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Eliminar Equipo"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#DC2626"/>

            </androidx.cardview.widget.CardView>

            <!-- Buscar -->
            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#FFFFFF">

                <Button
                        android:id="@+id/btnBuscar"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Buscar Equipo"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:backgroundTint="#0284C7"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</LinearLayout>