<?xml version="1.0" encoding="utf-8"?>
<ScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#f0fff4">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚽ PLAYMATCH"
                android:textColor="#16a34a"
                android:textStyle="bold"
                android:textSize="16sp"
                android:gravity="center"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Equipos"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="26sp"
                android:gravity="center"
                android:layout_marginBottom="6dp"/>

        <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué quieres hacer?"
                android:textColor="#4ade80"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#bbf7d0"
                android:layout_marginBottom="20dp"/>

        <!-- GUARDAR -->
        <LinearLayout
                android:id="@+id/tarjetaGuardar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                      android:text="💾" android:textSize="22sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Guardar" android:textStyle="bold" android:textSize="15sp"
                          android:textColor="#14532d"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Crear nuevo registro" android:textColor="#15803d" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- BUSCAR -->
        <LinearLayout
                android:id="@+id/tarjetaBuscar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                      android:text="🔍" android:textSize="22sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Buscar" android:textStyle="bold" android:textSize="15sp"
                          android:textColor="#14532d"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Buscar por ID" android:textColor="#15803d" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- EDITAR -->
        <LinearLayout
                android:id="@+id/tarjetaEditar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                      android:text="✏️" android:textSize="22sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Editar" android:textStyle="bold" android:textSize="15sp"
                          android:textColor="#14532d"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Modificar un registro" android:textColor="#15803d" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ELIMINAR -->
        <LinearLayout
                android:id="@+id/tarjetaEliminar"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                      android:text="🗑️" android:textSize="22sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Eliminar" android:textStyle="bold" android:textSize="15sp"
                          android:textColor="#14532d"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Borrar por ID" android:textColor="#15803d" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- VER TODOS -->
        <LinearLayout
                android:id="@+id/tarjetaVerTodos"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/card_background">
            <TextView android:layout_width="40dp" android:layout_height="wrap_content"
                      android:text="📋" android:textSize="22sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Ver todos" android:textStyle="bold" android:textSize="15sp"
                          android:textColor="#14532d"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                          android:text="Ver todos los registros" android:textColor="#15803d" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>