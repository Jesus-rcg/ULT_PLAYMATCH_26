<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F2F4F7">

    <!-- Toolbar -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">

        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#16a34a"/>

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Encuentros"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="18sp"
                android:gravity="center"/>

        <View
                android:layout_width="40dp"
                android:layout_height="40dp"/>

    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lista de todos los encuentros"
            android:textColor="#6B7280"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingVertical="8dp"
            android:background="#FFFFFF"
            android:layout_marginTop="1dp"/>

    <!-- Buscador -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF"
            android:layout_marginTop="1dp">

        <EditText
                android:id="@+id/etBuscar"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:hint="Buscar por lugar o jornada..."
                android:paddingHorizontal="12dp"
                android:background="@drawable/search_background"
                android:inputType="text"
                android:textSize="14sp"/>

        <Button
                android:id="@+id/btnBuscar"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Buscar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#16a34a"
                android:layout_marginStart="8dp"
                android:paddingHorizontal="16dp"/>

    </LinearLayout>

    <!-- Filtros de estado -->
    <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:layout_marginTop="1dp"
            android:paddingBottom="8dp">

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingTop="4dp">

            <Button
                    android:id="@+id/btnFiltroTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Todos"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#16a34a"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroPendiente"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Pendiente"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#D97706"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroJugando"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Jugando"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0284C7"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroFinalizado"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Finalizado"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#16a34a"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroAplazado"
                    android:layout_width="wrap_content"
                    android:layout_height="34dp"
                    android:text="Aplazado"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#DC2626"/>

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerEncuentros"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

</LinearLayout>