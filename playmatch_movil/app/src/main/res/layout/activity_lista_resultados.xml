<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#f0fff4">

    <!-- Header -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="#16a34a">

        <ImageButton
                android:id="@+id/btnVolver"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_revert"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"/>

        <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Resultados"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"/>

        <View
                android:layout_width="40dp"
                android:layout_height="40dp"/>

    </LinearLayout>

    <!-- Subtítulo -->
    <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lista de todos los resultados"
            android:textColor="#15803d"
            android:textSize="13sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#dcfce7"/>

    <!-- Barra de búsqueda -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:background="#FFFFFF">

        <EditText
                android:id="@+id/etBuscar"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="🔍 Buscar por ID de encuentro..."
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:inputType="number"
                android:layout_marginEnd="8dp"/>

        <Button
                android:id="@+id/btnBuscar"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:text="Buscar"
                android:textColor="#FFFFFF"
                android:backgroundTint="#16a34a"
                android:textSize="13sp"/>

    </LinearLayout>

    <!-- Filtros de goles -->
    <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingBottom="8dp">

        <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp">

            <Button
                    android:id="@+id/btnFiltroTodos"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Todos"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#16a34a"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroLocalGana"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🏠 Local Gana"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0284c7"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroVisitanteGana"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="✈️ Visitante Gana"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#ca8a04"
                    android:layout_marginEnd="8dp"/>

            <Button
                    android:id="@+id/btnFiltroEmpate"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="🤝 Empate"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#dc2626"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- Lista -->
    <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerResultados"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false"/>

</LinearLayout>