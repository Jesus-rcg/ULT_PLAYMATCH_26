<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E">

    <!-- Círculo decorativo superior -->
    <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_marginTop="-80dp"
            android:layout_marginStart="-60dp"
            android:alpha="0.18" />

    <!-- Círculo decorativo inferior -->
    <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="60dp"
            android:layout_marginEnd="-60dp"
            android:alpha="0.12" />

    <!-- Contenido principal -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="60dp"
                android:paddingBottom="32dp"
                android:minHeight="600dp">

            <!-- Logo y título -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="40dp">

                <TextView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:gravity="center"
                        android:textSize="32sp"
                        android:text="⚽"
                        android:background="@drawable/circulo_logo"
                        android:layout_gravity="center"
                        android:layout_marginBottom="14dp" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PlayMatch"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_gravity="center"
                        android:layout_marginBottom="4dp" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PANEL ADMINISTRATIVO"
                        android:textSize="11sp"
                        android:textColor="#73FFFFFF"
                        android:letterSpacing="0.15"
                        android:layout_gravity="center" />
            </LinearLayout>

            <!-- Campo Email -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORREO ELECTRÓNICO"
                    android:textSize="10sp"
                    android:textColor="#80FFFFFF"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/campo_login"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_email"
                        android:contentDescription=""
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5" />

                <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="admin@playmatch.com"
                        android:textColorHint="#66FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="textEmailAddress"
                        android:padding="0dp" />
            </LinearLayout>

            <!-- Campo Contraseña -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRASEÑA"
                    android:textSize="10sp"
                    android:textColor="#80FFFFFF"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp" />

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/campo_login"
                    android:padding="12dp"
                    android:layout_marginBottom="20dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:contentDescription=""
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5" />

                <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="••••••••"
                        android:textColorHint="#66FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:background="@null"
                        android:inputType="textPassword"
                        android:padding="0dp" />
            </LinearLayout>

            <!-- Botón iniciar sesión -->
            <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Iniciar sesión"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#534AB7"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="12dp" />

            <!-- Olvidé mi contraseña -->
            <Button
                    android:id="@+id/btnOlvideContrasena"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Olvidé mi contraseña"
                    android:textColor="#AFA9EC"
                    android:textSize="13sp"
                    android:background="@drawable/boton_outline_morado"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="8dp" />

            <!-- Registrarse -->
            <Button
                    android:id="@+id/btnRegistrarse"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Registrarse"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:backgroundTint="#534AB7"
                    android:stateListAnimator="@null"
                    android:layout_marginBottom="12dp" />

            <!-- Divider -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                <View
                        android:layout_width="0dp"
                        android:layout_height="0.5dp"
                        android:layout_weight="1"
                        android:background="#1AFFFFFF" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="acceso restringido"
                        android:textSize="11sp"
                        android:textColor="#40FFFFFF"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp" />

                <View
                        android:layout_width="0dp"
                        android:layout_height="0.5dp"
                        android:layout_weight="1"
                        android:background="#1AFFFFFF" />
            </LinearLayout>

            <!-- Badge solo administradores -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/campo_login"
                    android:padding="10dp"
                    android:layout_marginBottom="20dp">

                <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@android:drawable/ic_secure"
                        android:contentDescription=""
                        android:layout_marginEnd="6dp"
                        android:alpha="0.4" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solo administradores"
                        android:textSize="12sp"
                        android:textColor="#66FFFFFF" />
            </LinearLayout>

            <!-- Mensaje de error/éxito -->
            <TextView
                    android:id="@+id/message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

            <!-- Footer -->
            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PlayMatch © 2025 · v1.0"
                    android:textSize="11sp"
                    android:textColor="#40FFFFFF"
                    android:gravity="center" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>