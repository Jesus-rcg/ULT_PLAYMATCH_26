<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E">

    <!-- Círculo superior -->
    <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_marginTop="-80dp"
            android:layout_marginStart="-60dp"
            android:alpha="0.18"/>

    <!-- Círculo inferior -->
    <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="60dp"
            android:layout_marginEnd="-60dp"
            android:alpha="0.12"/>

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="60dp"
                android:paddingBottom="32dp">

            <!-- Botón volver -->
            <ImageButton
                    android:id="@+id/btnVolver"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_revert"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Volver"/>

            <!-- Logo -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="35dp">

                <TextView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:text="🔑"
                        android:textSize="32sp"
                        android:gravity="center"
                        android:background="@drawable/circulo_logo"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Recuperar contraseña"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="24sp"
                        android:layout_marginTop="14dp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Introduce el correo asociado a tu cuenta."
                        android:textColor="#80FFFFFF"
                        android:textSize="13sp"
                        android:layout_marginTop="6dp"/>
            </LinearLayout>

            <!-- Label -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORREO ELECTRÓNICO"
                    android:textSize="10sp"
                    android:textColor="#80FFFFFF"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="6dp"/>

            <!-- Campo correo -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/campo_login"
                    android:padding="12dp"
                    android:layout_marginBottom="24dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_email"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="correo@ejemplo.com"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:inputType="textEmailAddress"/>
            </LinearLayout>

            <!-- Botón enviar -->
            <Button
                    android:id="@+id/btnEnviarCodigo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Enviar código"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#534AB7"
                    android:stateListAnimator="@null"/>

            <!-- Volver -->
            <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Volver al inicio"
                    android:textColor="#80FFFFFF"
                    android:textSize="13sp"
                    android:background="@null"
                    android:layout_marginTop="10dp"/>

            <!-- Mensaje -->
            <TextView
                    android:id="@+id/txtMensaje"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:layout_marginTop="20dp"/>

        </LinearLayout>

    </ScrollView>

</FrameLayout>