<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E">

    <!-- Círculo superior -->
    <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginStart="-60dp"
            android:layout_marginTop="-80dp"
            android:alpha="0.18"
            android:background="@drawable/circulo_morado_difuso"/>

    <!-- Círculo inferior -->
    <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="-60dp"
            android:layout_marginBottom="60dp"
            android:alpha="0.12"
            android:background="@drawable/circulo_morado_difuso"/>

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="50dp"
                android:paddingBottom="32dp"
                android:minHeight="700dp">

            <!-- Volver -->

            <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="30dp">

                <ImageButton
                        android:id="@+id/btnVolver"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@android:drawable/ic_menu_revert"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Volver"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Volver al inicio"
                        android:textColor="#AFA9EC"
                        android:textSize="13sp"/>
            </LinearLayout>

            <!-- Logo -->

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="30dp">

                <TextView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="@drawable/circulo_logo"
                        android:gravity="center"
                        android:text="⚽"
                        android:textSize="32sp"
                        android:layout_marginBottom="14dp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PlayMatch"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="26sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CREAR CUENTA"
                        android:textColor="#73FFFFFF"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"/>
            </LinearLayout>

            <!-- Nombre y apellido -->

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOMBRE"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginBottom="6dp"/>

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/campo_login"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                        <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="8dp"
                                app:srcCompat="@mipmap/nombre"
                                android:alpha="0.5"/>

                        <EditText
                                android:id="@+id/etNombre"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@null"
                                android:hint="Nombre"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#66FFFFFF"/>
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="APELLIDO"
                            android:textColor="#80FFFFFF"
                            android:textSize="10sp"
                            android:layout_marginBottom="6dp"/>

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/campo_login"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp">

                        <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginEnd="8dp"
                                app:srcCompat="@mipmap/nombre"
                                android:alpha="0.5"/>

                        <EditText
                                android:id="@+id/etApellido"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:background="@null"
                                android:hint="Apellido"
                                android:textColor="#FFFFFF"
                                android:textColorHint="#66FFFFFF"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Email -->

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CORREO ELECTRÓNICO"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/campo_login"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_dialog_email"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="correo@ejemplo.com"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:inputType="textEmailAddress"/>

            </LinearLayout>

            <!-- Teléfono -->

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TELÉFONO"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/campo_login"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_call"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etTelefono"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="3001234567"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:inputType="phone"/>

            </LinearLayout>

            <!-- Fecha -->

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FECHA DE NACIMIENTO"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

            <LinearLayout
                    android:id="@+id/layoutFecha"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/campo_login"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_my_calendar"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etFechaNacimiento"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="Seleccionar fecha"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:focusable="false"
                        android:clickable="true"/>

            </LinearLayout>

            <!-- Contraseña -->

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONTRASEÑA"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/campo_login"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="********"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:inputType="textPassword"/>

            </LinearLayout>

            <!-- Confirmar contraseña -->

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONFIRMAR CONTRASEÑA"
                    android:textColor="#80FFFFFF"
                    android:textSize="10sp"
                    android:layout_marginBottom="6dp"/>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/campo_login"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="12dp"
                    android:layout_marginBottom="24dp">

                <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:layout_marginEnd="10dp"
                        android:alpha="0.5"/>

                <EditText
                        android:id="@+id/etConfirmarPassword"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@null"
                        android:hint="********"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#66FFFFFF"
                        android:inputType="textPassword"/>

            </LinearLayout>

            <Button
                    android:id="@+id/btnRegistrarse"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="Registrarse"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#534AB7"
                    android:stateListAnimator="@null"/>

            <Button
                    android:id="@+id/btnYaTengoCuenta"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Ya tengo una cuenta"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#534AB7"
                    android:stateListAnimator="@null"
                    android:layout_marginTop="8dp"/>

        </LinearLayout>

    </ScrollView>

</FrameLayout>