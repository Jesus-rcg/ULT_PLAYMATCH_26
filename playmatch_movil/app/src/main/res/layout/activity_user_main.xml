<?xml version="1.0" encoding="utf-8"?>

<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
             xmlns:app="http://schemas.android.com/apk/res-auto"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:background="#1A1A2E">

    <!-- Fondo superior -->
    <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_marginStart="-70dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.15"
            android:background="@drawable/circulo_morado_difuso"/>

    <!-- Fondo inferior -->
    <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="45dp"
            android:layout_marginEnd="-70dp"
            android:alpha="0.10"
            android:background="@drawable/circulo_morado_difuso"/>

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:paddingBottom="75dp">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="#4B43A8"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="PlayMatch"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="20sp"/>


            </LinearLayout>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bienvenido de nuevo,"
                        android:textColor="#8F8AAE"
                        android:textSize="14sp"/>

                <TextView
                        android:id="@+id/txtNombreUsuario"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Juan Pérez 👋"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="28sp"/>

            </LinearLayout>

            <!-- TÍTULO -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="TORNEOS ACTIVOS"
                        android:textColor="#8F8AAE"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"
                        android:textSize="13sp"/>

                <TextView
                        android:id="@+id/txtVerTodosTorneos"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VER TODOS"
                        android:textColor="#AFA9EC"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                    android:id="@+id/cardTorneo1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="#2C2A45"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                    <TextView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/circulo_logo"
                            android:gravity="center"
                            android:text="🏆"
                            android:textSize="20sp"/>

                    <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                        <TextView
                                android:id="@+id/txtNombreTorneo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Copa Bogotá 2025"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="18sp"/>

                        <TextView
                                android:id="@+id/txtInfoTorneo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Fútbol 11 · Bogotá"
                                android:textColor="#A0A0B8"
                                android:textSize="13sp"/>

                    </LinearLayout>

                    <TextView
                            android:id="@+id/txtEstado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_activo"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:text="Activo"
                            android:textColor="#5EF0AE"
                            android:textStyle="bold"
                            android:textSize="12sp"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="RESULTADOS RECIENTES"
                        android:textStyle="bold"
                        android:textColor="#8F8AAE"
                        android:textSize="13sp"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VER TODOS"
                        android:textStyle="bold"
                        android:textColor="#AFA9EC"
                        android:textSize="13sp"/>

            </LinearLayout>

            <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="18dp"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="#2C2A45">

                <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Final"
                            android:textColor="#B6B6C8"
                            android:textSize="12sp"/>

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:gravity="center_vertical">

                        <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Atlético FC"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="17sp"/>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3 - 2"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="22sp"/>

                        <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:gravity="end"
                                android:text="Real Club"
                                android:textColor="#FFFFFF"
                                android:textStyle="bold"
                                android:textSize="17sp"/>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- MIS EQUIPOS -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_marginEnd="18dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="10dp"
                    android:gravity="center_vertical">

                <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="EQUIPOS"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#8F8AAE"/>

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VER TODOS"
                        android:textStyle="bold"
                        android:textSize="13sp"
                        android:textColor="#AFA9EC"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEquipos"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:clipToPadding="false"/>

            <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Explora todos los equipos registrados"
                    android:textAlignment="center"
                    android:textColor="#7E7EA4"
                    android:textSize="13sp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="20dp"/>
        </LinearLayout>

    </ScrollView>

</FrameLayout>