<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

        <!-- Jornada y estado -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

            <TextView
                    android:id="@+id/tvJornada"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Jornada 1"
                    android:textColor="#111827"
                    android:textStyle="bold"
                    android:textSize="13sp"/>

            <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pendiente"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/badge_pendiente"/>

        </LinearLayout>

        <!-- Equipos -->
        <TextView
                android:id="@+id/tvEquipos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Local vs Visitante"
                android:textColor="#111827"
                android:textStyle="bold"
                android:textSize="15sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>

        <!-- Fecha y hora -->
        <TextView
                android:id="@+id/tvFechaHora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Fecha - Hora"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="4dp"/>

        <!-- Lugar -->
        <TextView
                android:id="@+id/tvLugar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lugar"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="10dp"/>

        <!-- Línea divisora -->
        <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F3F4F6"
                android:layout_marginBottom="8dp"/>

        <!-- Botones -->
        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

            <Button
                    android:id="@+id/btnEditar"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Editar"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:backgroundTint="#2563EB"
                    android:layout_marginEnd="6dp"
                    android:visibility="gone"/>

            <Button
                    android:id="@+id/btnEliminar"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Eliminar"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:backgroundTint="#DC2626"
                    android:layout_marginStart="6dp"
                    android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>