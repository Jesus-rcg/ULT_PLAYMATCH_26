<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginBottom="12dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/card_background">

    <!-- Jornada y estado -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

        <TextView
                android:id="@+id/tvJornada"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jornada 1"
                android:textColor="#14532d"
                android:textStyle="bold"
                android:textSize="13sp"/>

        <TextView
                android:id="@+id/tvEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pendiente"
                android:textColor="#16a34a"
                android:textSize="12sp"
                android:textStyle="bold"/>

    </LinearLayout>

    <!-- Equipos -->
    <TextView
            android:id="@+id/tvEquipos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Local vs Visitante"
            android:textColor="#14532d"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

    <!-- Fecha y hora -->
    <TextView
            android:id="@+id/tvFechaHora"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha - Hora"
            android:textColor="#15803d"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="4dp"/>

    <!-- Lugar -->
    <TextView
            android:id="@+id/tvLugar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lugar"
            android:textColor="#15803d"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

    <!-- Botones -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

        <ImageButton
                android:id="@+id/btnEditar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_edit"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#16a34a"
                android:visibility="gone"/>

        <ImageButton
                android:id="@+id/btnEliminar"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="#dc2626"
                android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>