<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rectangulo"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

        <TextView
                android:id="@+id/txtAvatar"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#3C3489"
                android:background="@drawable/circulo_morado"
                android:layout_marginEnd="10dp" />

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/txtNombre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            <TextView
                    android:id="@+id/txtEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#888780" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

        <TextView
                android:id="@+id/txtRol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#3C3489"
                android:background="@drawable/rectangulo_morado"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:layout_marginEnd="8dp" />

        <View
                android:id="@+id/dotEstado"
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/circulo_verde"
                android:layout_marginEnd="4dp" />

        <TextView
                android:id="@+id/txtEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="10sp"
                android:textColor="#888780" />

        <TextView
                android:id="@+id/txtId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#BDBCB8" />
    </LinearLayout>

    <View
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="0"/>

    <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <Button
                android:id="@+id/btnEditar"
                android:text="Editar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:drawableLeft="@drawable/boton_editar"
                android:layout_weight="1"
                android:backgroundTint="#2196F3"
                android:layout_marginRight="20dp"/>
        <Button
                android:id="@+id/btnEliminar"
                android:text="Eliminar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:drawableLeft="@drawable/boton_eliminar"
                android:backgroundTint="#F33446"
                android:layout_weight="1"/>
    </LinearLayout>

</LinearLayout>
