<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#1A1A2E">

    <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_marginTop="-70dp"
            android:layout_marginStart="-50dp"
            android:alpha="0.13" />

    <View
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:background="@drawable/circulo_morado_difuso"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="30dp"
            android:layout_marginEnd="-50dp"
            android:alpha="0.09" />

    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="45dp"
                android:padding="18dp"
                android:paddingTop="52dp"
                android:paddingBottom="28dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="28dp"
                    >

                <TextView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="⚽"
                        android:textSize="18sp"
                        android:background="@drawable/circulo_logo"
                        android:layout_marginEnd="10dp"/>

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PlayMatch"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PANEL ADMINISTRATIVO"
                            android:textSize="10sp"
                            android:textColor="#62FFFFFF"
                            android:letterSpacing="0.12"/>
                </LinearLayout>
            </LinearLayout>
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GESTIÓN"
                    android:textSize="10sp"
                    android:textColor="#52FFFFFF"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="2dp"/>

            <LinearLayout
                    android:id="@+id/cardUsuarios"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tarjeta_menu"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp">

                <ImageButton
                        android:id="@+id/btnUser"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:srcCompat="@mipmap/usuarios"
                        android:background="@drawable/icono_menu_bg"
                        android:scaleType="fitCenter"
                        android:contentDescription="Usuarios"
                        android:padding="10dp"
                        android:layout_marginEnd="14dp"/>

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Usuarios"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gestionar cuentas de acceso"
                            android:textSize="11sp"
                            android:textColor="#62FFFFFF"
                            android:layout_marginTop="2dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Equipos + Jugadores -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="18dp">

                <LinearLayout
                        android:id="@+id/cardEquipos"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginEnd="5dp">

                    <ImageButton
                            android:id="@+id/btnEquipos"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:srcCompat="@mipmap/equipos"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Equipos"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Equipos"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/cardJugadores"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginStart="5dp">

                    <ImageButton
                            android:id="@+id/btnJugadores"
                            android:layout_width=" 48dp"
                            android:layout_height="48dp"
                            app:srcCompat="@mipmap/jugadores"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Jugadores"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jugadores"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Label Competencia -->
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="COMPETENCIA"
                    android:textSize="10sp"
                    android:textColor="#52FFFFFF"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp"
                    android:layout_marginStart="2dp"/>

            <!-- Torneos + Encuentros -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                <LinearLayout
                        android:id="@+id/cardTorneos"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginEnd="5dp">

                    <ImageButton
                            android:id="@+id/btnTorneo"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:srcCompat="@mipmap/torneo"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Torneos"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Torneos"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/cardEncuentros"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginStart="5dp">

                    <ImageButton
                            android:id="@+id/btnVersus"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:srcCompat="@mipmap/versus"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Versus"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Encuentros"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Posiciones + Resultados -->
            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                <LinearLayout
                        android:id="@+id/cardPosiciones"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginEnd="5dp">

                    <ImageButton
                            android:id="@+id/btnPosiciones"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:srcCompat="@mipmap/posiciones"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Posiciones"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Posiciones"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                        android:id="@+id/cardResultados"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/tarjeta_menu"
                        android:padding="10dp"
                        android:layout_marginStart="5dp"
                >

                    <ImageButton
                            android:id="@+id/btnResultados"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            app:srcCompat="@mipmap/resultados"
                            android:background="@drawable/icono_menu_bg"
                            android:scaleType="fitCenter"
                            android:contentDescription="Resultados"
                            android:padding="10dp"
                            android:layout_marginBottom="10dp"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Resultados"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                    android:id="@+id/cardCronologias"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/tarjeta_menu"
                    android:padding="10dp"
                    android:layout_marginBottom="10dp">

                <ImageButton
                        android:id="@+id/btnCronologia"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:srcCompat="@mipmap/cronologia"
                        android:background="@drawable/icono_menu_bg"
                        android:scaleType="fitCenter"
                        android:contentDescription="Cronologia"
                        android:padding="10dp"
                        android:layout_marginEnd="14dp"/>

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cronologías"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"/>

                    <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gestionar cronologías de partidos"
                            android:textSize="11sp"
                            android:textColor="#62FFFFFF"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</FrameLayout>