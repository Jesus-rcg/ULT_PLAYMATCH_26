<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F5F5F5">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

        <TextView
                android:text="Editar Encuentro"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        <EditText
                android:id="@+id/etId"
                android:hint="ID del encuentro a editar *"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <Button
                android:id="@+id/btnCargar"
                android:text="Cargar datos"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="20dp"
                android:backgroundTint="#607D8B"/>

        <EditText
                android:id="@+id/etIdTorneo"
                android:hint="ID Torneo *"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etIdEquipoLocal"
                android:hint="ID Equipo Local *"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etIdEquipoVisitante"
                android:hint="ID Equipo Visitante *"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etFecha"
                android:hint="Fecha * (yyyy-MM-dd HH:mm:ss)"
                android:inputType="text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etLugar"
                android:hint="Lugar"
                android:inputType="text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etJornada"
                android:hint="Jornada (Mañana / Tarde / Noche)"
                android:inputType="text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etIdArbitro"
                android:hint="ID Árbitro"
                android:inputType="number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"/>

        <EditText
                android:id="@+id/etEstado"
                android:hint="Estado (Programado / En curso / Finalizado / Cancelado)"
                android:inputType="text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"/>

        <Button
                android:id="@+id/btnGuardar"
                android:text="Guardar Cambios"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="#3F51B5"/>

    </LinearLayout>
</ScrollView>