<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/rectangulo"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

        <TextView
                android:id="@+id/txtPosicion"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#633806"
                android:background="@drawable/circulo_posicion"
                android:layout_marginEnd="10dp" />

        <TextView
                android:id="@+id/txtAvatarEquipo"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#3C3489"
                android:background="@drawable/circulo_morado"
                android:layout_marginEnd="10dp" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

            <TextView
                    android:id="@+id/txtNombreEquipo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            <TextView
                    android:id="@+id/txtNombreTorneo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#888780" />

        </LinearLayout>

        <TextView
                android:id="@+id/txtPuntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#3C3489"
                android:background="@drawable/rectangulo_morado"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

    </LinearLayout>

    <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="10dp" />

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtJugados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PJ"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtGanados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="G"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtEmpatados"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtPerdidos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="P"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtGF"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GF"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtGC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GC"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>

        <View android:layout_width="0.5dp" android:layout_height="32dp" android:background="#E0E0E0" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
            <TextView
                    android:id="@+id/txtDG"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DG"
                    android:textSize="10sp"
                    android:textColor="#888780"
                    android:gravity="center" />
        </LinearLayout>


    </LinearLayout>

    <View
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_weight="0"/>

    <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

        <Button
                android:id="@+id/btnEditar"
                android:text="Editar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:drawableLeft="@drawable/boton_editar"
                android:layout_weight="1"
                android:backgroundTint="#2196F3"
                android:layout_marginRight="20dp"/>
        <Button
                android:id="@+id/btnEliminar"
                android:text="Eliminar"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:drawableLeft="@drawable/boton_eliminar"
                android:backgroundTint="#F33446"
                android:layout_weight="1"/>
    </LinearLayout>


</LinearLayout>